# A = transition matrix (ha), rows = 2015, cols = 2020
# Convert to percentages of 2015 class area
transition_pct <- prop.table(A, margin = 1) * 100
# Convert to tidy table
transition_tbl <- as.data.frame(as.table(transition_pct)) |>
rename(
From_2015 = Var1,
To_2020   = Var2,
Percent   = Freq
) |>
filter(Percent > 0) |>
arrange(desc(Percent))
transition_tbl
# --- 1) Tidy transitions in BOTH ha and % of 2015 class ---
# A = matrix of transition area (ha), rows = 2015, cols = 2020
trans_ha <- as.data.frame(as.table(A)) |>
rename(from_2015 = Var1, to_2020 = Var2, area_ha = Freq)
# Percent of each 2015 class that went to each 2020 class
trans_pct <- prop.table(A, margin = 1) * 100
trans_pct_df <- as.data.frame(as.table(trans_pct)) |>
rename(from_2015 = Var1, to_2020 = Var2, pct_of_2015 = Freq)
# Join ha + %
trans <- trans_ha |>
left_join(trans_pct_df, by = c("from_2015","to_2020")) |>
mutate(
area_ha = as.numeric(area_ha),
pct_of_2015 = as.numeric(pct_of_2015)
)
# --- 2) Exclude persistence (same class -> same class) ---
trans_change <- trans |>
filter(from_2015 != to_2020) |>
filter(area_ha > 0)
# --- 3) Largest cross-class transition (by area, not %) ---
top_transition_area <- trans_change |>
slice_max(order_by = area_ha, n = 1, with_ties = FALSE)
top_transition_area
# Use: top_transition_area$from_2015, $to_2020, $area_ha, $pct_of_2015
# --- 4) Largest cross-class transition (by % of origin class) ---
top_transition_pct <- trans_change |>
slice_max(order_by = pct_of_2015, n = 1, with_ties = FALSE)
annual_out <- trans_change |>
filter(
from_2015 == "Annual agriculture",
to_2020 %in% c("Marginalized", "Perennial agriculture", "Forest", "Wetland", "Water")
) |>
arrange(desc(pct_of_2015))
annual_out
perennial_out <- trans_change |>
filter(
from_2015 == "Perennial agriculture",
to_2020 %in% c("Marginalized", "Annual agriculture", "Forest", "Wetland", "Water")
) |>
arrange(desc(pct_of_2015))
agri_transitions <- bind_rows(
annual_out |> mutate(origin = "Annual agriculture"),
perennial_out |> mutate(origin = "Perennial agriculture")
) |>
select(origin, from_2015, to_2020, area_ha, pct_of_2015)
agri_transitions

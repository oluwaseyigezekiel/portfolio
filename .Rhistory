# Forest (2015) to Agriculture (2020: annual or perennial)
# Forest (2015) -> Agriculture (2020: annual or perennial)
f2ag <- (harm15 == 5) & (harm20 %in% c(3, 4))
# Area-true hectares
cell_ha <- cellSize(harm15, unit = "ha")
f2ag_ha <- global(cell_ha * f2ag, "sum", na.rm = TRUE)[1,1]
# Percent of valid overlap area
valid <- !is.na(harm15) & !is.na(harm20)
total_ha <- global(cell_ha * valid, "sum", na.rm = TRUE)[1,1]
pct_f2ag <- 100 * f2ag_ha / total_ha
# Binary conversion raster (1 = conversion, NA = background)
f2ag_bin <- ifel(f2ag, 1, NA)
# Patch areas (ha) using landscapemetrics
f2ag_r  <- raster::raster(f2ag_bin)
f2ag_pa <- lsm_p_area(f2ag_r, directions = 8)   # <- this is the object you'll use
# Summary table
f2ag_patch_stats <- data.frame(
forest_to_ag_ha     = f2ag_ha,
pct_of_landscape    = pct_f2ag,
n_patches           = nrow(f2ag_pa),
mean_patch_ha       = mean(f2ag_pa$value, na.rm = TRUE),
median_patch_ha     = median(f2ag_pa$value, na.rm = TRUE),
max_patch_ha        = max(f2ag_pa$value, na.rm = TRUE),
prop_patches_lt1ha  = mean(f2ag_pa$value < 1, na.rm = TRUE) * 100 # How many forest patches are less than 1ha?
) |>
mutate(across(where(is.numeric), ~ round(.x, 2)))
f2ag_patch_stats
patches_lt1ha <- mean(f2ag_pa$value < 1) *100
patches_lt1ha
# Save as GeoTIFF
writeRaster(
f2ag_bin,
"outputs/Forest_to_Agriculture_2015_2020.tif",
overwrite = TRUE,
gdal = c("COMPRESS=LZW")
)
forest15 <- ifel(harm15 == 5, 1, NA)

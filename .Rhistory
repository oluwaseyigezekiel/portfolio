# --- 4) Force distinct colors + clear outside labels + legend + headers ----
LEFT_ONLY_LABELS <- FALSE   # set TRUE if you want labels only on the 2015 side
p <- htmlwidgets::onRender(p, htmlwidgets::JS(sprintf("
function(el, x) {
var svg = d3.select(el).select('svg');
var width  = svg.node().getBoundingClientRect().width;
var height = +svg.attr('height');
// allow overflow so outside labels don't get clipped
svg.style('overflow', 'visible');
// ===== Color map (keys must match your class names exactly) =====
var colorMap = {
'Water': '#1f77b4',
'Marginalized': '#d62728',
'Annual agriculture': '#ff7f0e',
'Perennial agriculture': '#7fc97f',
'Forest': '#006400',
'Wetland': '#6a0dad'
};
function baseName(s){
return String(s).split(' [')[0].trim();
}
// ===== Force node colors (target rects) =====
d3.select(el).selectAll('.node rect')
.style('fill', function(d){
return colorMap[ baseName(d.name) ] || 'grey';
})
.style('stroke', '#000')
.style('stroke-width', '0.35px');
// ===== Force link colors by SOURCE class =====
d3.select(el).selectAll('.link')
.style('stroke', function(d){
return colorMap[ baseName(d.source.name) ] || 'grey';
})
.style('stroke-opacity', 0.45);
// ===== Node tooltips (use your R-provided titles when possible) =====
// networkD3 already adds <title> to nodes/links; we overwrite nicely:
d3.select(el).selectAll('.node').select('title')
.text(function(d){
// try to find matching title in x.nodes (first match is fine because title differs by side only)
var nm = baseName(d.name);
var hits = x.nodes.filter(function(n){ return n.name === nm; });
if(hits && hits.length > 0 && hits[0].title) return hits[0].title;
return nm;
});
d3.select(el).selectAll('.link').select('title')
.text(function(d,i){
return d.source.name + ' → ' + d.target.name + '\\nArea: ' + x.links.area_txt[i] + ' ha';
});
// ===== Remove default labels (we'll draw outside labels) =====
d3.select(el).selectAll('.node text').remove();
// ===== Outside labels =====
var labelOffset = 10;
d3.select(el).selectAll('.node')
.append('text')
.attr('class', 'outside-label')
.attr('y', function(d){ return d.dy/2; })
.attr('dy', '0.35em')
.style('fill', 'black')
.style('font-size', '13px')
.style('font-weight', '600')
.text(function(d){ return baseName(d.name); })
.attr('text-anchor', function(d){
return (d.x < width/2) ? 'end' : 'start';
})
.attr('x', function(d){
return (d.x < width/2) ? -labelOffset : (d.dx + labelOffset);
});
// ===== LEFT-ONLY LABELS toggle =====
var leftOnly = %s;
if(leftOnly){
d3.select(el).selectAll('.node').each(function(d){
if (d.x > width/2) d3.select(this).select('text.outside-label').style('opacity', 0);
else d3.select(this).select('text.outside-label').style('opacity', 1);
});
}
// ===== Column headers =====
svg.selectAll('.year-header').remove();
svg.append('text')
.attr('class','year-header')
.attr('x', 10).attr('y', 20)
.style('font-size','16px')
.style('font-weight','bold')
.style('fill','black')
.text('2015');
svg.append('text')
.attr('class','year-header')
.attr('x', width - 10).attr('y', 20)
.attr('text-anchor','end')
.style('font-size','16px')
.style('font-weight','bold')
.style('fill','black')
.text('2020');
// ===== Legend below =====
// add space for legend
svg.attr('height', height + 65);
var legendY = height + 50;
svg.selectAll('.legend').remove();
var legend = svg.append('g')
.attr('class','legend')
.attr('transform','translate(10,' + legendY + ')');
var legendItems = ['Water','Marginalized','Annual agriculture','Perennial agriculture','Forest','Wetland'];
var lg = legend.selectAll('.leg-item')
.data(legendItems)
.enter()
.append('g')
.attr('class','leg-item')
.attr('transform', function(d,i){ return 'translate(' + (i*155) + ',0)'; });
lg.append('rect')
.attr('width', 14).attr('height', 14)
.attr('y', -12)
.style('fill', function(d){ return colorMap[d]; })
.style('stroke', '#000')
.style('stroke-width', '0.35px');
lg.append('text')
.attr('x', 20)
.attr('y', 0)
.style('fill','black')
.style('font-size','12px')
.style('font-weight','600')
.text(function(d){ return d; });
}
", ifelse(LEFT_ONLY_LABELS, "true", "false"))))
p
htmlwidgets::saveWidget(p, "sankey_2015_2020.html", selfcontained = TRUE)

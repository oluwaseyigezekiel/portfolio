gdal = c("COMPRESS=LZW")
)
### Adjacency Index (Annual adjacent to Perennial) — with area (ha) + patches
pct_annual_adj_perennial <- function(lu, annual = 3, perennial = 4) {
w <- matrix(1, 3, 3); w[2, 2] <- 0
# count perennial neighbours (8-neighbour)
neigh_per <- focal(lu == perennial, w = w, fun = sum,
na.rm = TRUE, pad = TRUE, fillvalue = 0)
annual_cells <- (lu == annual)
annual_adj   <- annual_cells & (neigh_per > 0)
# counts + percent
total_annual <- global(annual_cells, "sum", na.rm = TRUE)[1,1]
adj_annual   <- global(annual_adj,   "sum", na.rm = TRUE)[1,1]
pct <- ifelse(total_annual == 0, NA, 100 * adj_annual / total_annual)
# --- area in ha ---
cell_ha <- cellSize(lu, unit = "ha")
annual_area_ha <- global(cell_ha * annual_cells, "sum", na.rm = TRUE)[1,1]
adj_area_ha    <- global(cell_ha * annual_adj,   "sum", na.rm = TRUE)[1,1]
# --- adjacency patches (8-neighbour clumps) ---
adj_bin <- ifel(annual_adj, 1, NA)
cl <- patches(adj_bin, directions = 8)
patch_ids <- unique(values(cl))
patch_ids <- patch_ids[!is.na(patch_ids)]
n_patches <- length(patch_ids)
# --- patch area summary (ha) (optional but good for Results) ---
# zonal() output column name can vary; grab the non-zone numeric column safely
pa <- as.data.frame(zonal(cell_ha, cl, fun = "sum", na.rm = TRUE))
if (nrow(pa) == 0) {
mean_patch_ha <- NA_real_
median_patch_ha <- NA_real_
max_patch_ha <- NA_real_
} else {
num_cols <- names(pa)[sapply(pa, is.numeric)]
num_cols <- setdiff(num_cols, "zone")
patch_areas <- pa[[num_cols[1]]]
mean_patch_ha   <- mean(patch_areas, na.rm = TRUE)
median_patch_ha <- median(patch_areas, na.rm = TRUE)
max_patch_ha    <- max(patch_areas, na.rm = TRUE)
}
data.frame(
total_annual_cells = total_annual,
adjacent_cells     = adj_annual,
pct_adjacent       = pct,
annual_area_ha     = annual_area_ha,
adjacent_area_ha   = adj_area_ha,
n_adj_patches      = n_patches,
mean_patch_ha      = mean_patch_ha,
median_patch_ha    = median_patch_ha,
max_patch_ha       = max_patch_ha
)
}
adj15 <- pct_annual_adj_perennial(harm15) |> mutate(year = 2015)
adj20 <- pct_annual_adj_perennial(harm20) |> mutate(year = 2020)
adjacency_df <- bind_rows(adj15, adj20) |>
mutate(
pct_adjacent = round(pct_adjacent, 1),
annual_area_ha = round(annual_area_ha, 2),
adjacent_area_ha = round(adjacent_area_ha, 2),
mean_patch_ha = round(mean_patch_ha, 2),
median_patch_ha = round(median_patch_ha, 2),
max_patch_ha = round(max_patch_ha, 2)
)
adjacency_df
top10_share <- function(lu, annual = 3, perennial = 4){
w <- matrix(1, 3, 3); w[2, 2] <- 0
neigh_per <- focal(lu == perennial, w = w, fun = sum,
na.rm = TRUE, pad = TRUE, fillvalue = 0)
annual_adj <- (lu == annual) & (neigh_per > 0)
cell_ha <- cellSize(lu, unit = "ha")
cl <- patches(ifel(annual_adj, 1, NA), directions = 8)
pa <- as.data.frame(zonal(cell_ha, cl, fun = "sum", na.rm = TRUE))
if(nrow(pa) == 0) return(NA_real_)
num_cols <- names(pa)[sapply(pa, is.numeric)]
num_cols <- setdiff(num_cols, "zone")
s <- sort(pa[[num_cols[1]]], decreasing = TRUE)
k <- max(1, ceiling(0.10 * length(s)))
sum(s[1:k], na.rm = TRUE) / sum(s, na.rm = TRUE)
}
share15 <- top10_share(harm15)
share20 <- top10_share(harm20)
c(share15 = round(100*share15, 1), share20 = round(100*share20, 1))
gg_adj <- ggplot(adjacency_df,
aes(x = year, y = pct_adjacent)) +
geom_col(
width = 0.6,
fill = "grey75",
color = "grey20",
linewidth = 0.15) +
geom_text(aes(label = paste0(pct_adjacent, "%")),
vjust = -0.42, size = 3) +
labs(
x = "Year",
y = "Adjacent annual agriculture (%)"
) +
scale_y_continuous(
expand = expansion(mult = c(0.05, 0.15))
) +
theme_classic() +
theme(
legend.position = "none"
)
gg_adj
